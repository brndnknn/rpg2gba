script Map002_EV004_Page1 {
    lock
    faceplayer
    random(3)
    copyvar(VAR_THEO_FOLLOW_CHATTER, VAR_RESULT)
    if (var(VAR_THEO_FOLLOW_CHATTER) == 1) {
        msgbox("Hey, man. No, I won't battle you, but listen. This Gym Leader? Don't take him for granted; he's much harder than Maria in Nowtoch was.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 2) {
        msgbox("Davern uses Ground, Water, Rock, and Dark-types. It's kind of hard to prepare for him.")
    } else {
        msgbox("I just got beaten soundly at the Gym. Stock up on supplies at the mart before you try it.")
    }
    release
    end
}


script Map002_EV007_Page1 {
    lock
    faceplayer
    random(2)
    copyvar(VAR_THEO_FOLLOW_CHATTER, VAR_RESULT)
    addvar(VAR_THEO_FOLLOW_CHATTER, 1)
    if (var(VAR_THEO_FOLLOW_CHATTER) == 2) {
        msgbox("I like the Pokémon Owten! Owten Owten Owten! It's so cute!")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 1) {
        msgbox("Owten evolves at level 21 into an even fluffier flying cat owl thing!")
    }
    release
    end
}


