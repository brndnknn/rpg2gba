script Map002_EV001_Page1 {
    lock
    faceplayer
    msgbox("Hello, and welcome to the Pokémon Center.\pWe restore your tired Pokémon to full health.")
    msgbox("Would you like to rest your Pokémon?", MSGBOX_YESNO)
    if (var(VAR_RESULT) == 1) {
        msgbox("OK, I'll take your Pokémon for a few seconds.")
        healparty
        # UNHANDLED: command 111 Kernel.pbPokerus? conditional — see unhandled[]
        msgbox("Thank you for waiting.\pWe've restored your Pokémon to full health.\pWe hope to see you again!")
    } else {
        msgbox("We hope to see you again!")
    }
    release
    end
}

script Map002_EV001_Page2 {
    lock
    faceplayer
    msgbox("First, you should restore your Pokémon to full health.")
    healparty
    msgbox("Your Pokémon have been healed to perfect health.\pWe hope you excel!")
    clearflag(FLAG_DREAM_ACTIVE)
    release
    end
}


script Map002_EV002_Page1 {
    lockall
