script Map008_EV064_TheoQuest_Page1 {
    lock
    faceplayer
    msgbox("Good. Now I think everybody's here.")
    msgbox("Ready to go, {PLAYER}? We're going into the Hazard Zone. It's gonna be pretty dangerous... plus, it'll be swarming with Nuclear Pokémon. But I'm not afraid! I can handle a few Nuclears, no problem!")
    msgbox("So, how about you? All set to head out?", MSGBOX_YESNO)
    if (var(VAR_RESULT) == 1) {
        msgbox("About time!\nLet's do this!")
        msgbox("Get on the boat, all of you.\pI'll explain the mission on the way over.")
        fadescreen(FADE_TO_BLACK)
        # UNHANDLED: warp destination map 188 needs resolution — see unhandled[]
        warp(MAP_URANIUM_188, 22, 9)
        fadescreen(FADE_FROM_BLACK)
        setvar(VAR_THEO_FOLLOW_PROGRESS, 16)
    } else {
        msgbox("Well, what are you waiting for?\nHurry it up! We gotta stop CURIE!")
    }
    release
    end
}

