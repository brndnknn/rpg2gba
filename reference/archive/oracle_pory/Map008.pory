script Map008_EV006_Trainer1_Page1 {
    lock
    faceplayer
    # UNHANDLED: command 355 Kernel.pbNoticePlayer — see unhandled[]
    clearflag(FLAG_BLACKBELT_POP_DEFEATED)
    msgbox("I do not desire to initiate conflict. Therefore, I shall give you a choice. Would you like to battle?", MSGBOX_YESNO)
    if (var(VAR_RESULT) == 1) {
        msgbox("Very well, let us fight!")
        trainerbattle_single(TRAINER_BLACKBELT_POP, "", "I have much to learn, it seems.")
        setflag(FLAG_MAP008_EVENT006_SSA)
        setflag(FLAG_BLACKBELT_POP_DEFEATED)
    } else {
        msgbox("That is fine. I will wait, should you desire to challenge me later.")
    }
    release
    end
}

