script Map008_EV019_Sailor_Page1 {
    lock
    faceplayer
    checkitem(ITEM_KELLYNLETTER, 1)
    if (var(VAR_RESULT) == FALSE) {
        # CHECK: code 111 tested $PokemonBag.pbQuantity(PBItems::KELLYNLETTER)==0 (player lacks letter) — verify checkitem / ITEM_KELLYNLETTER; see unhandled[]
        msgbox("This ship'll take ya to the Nuclear Power Plant construction site. They're buildin' a new one on that island, ya know. But, ehh, you're only a kid. Sorry kid, but a construction site ain't a playground. Scram!")
    } else {
        msgbox("This ship'll take ya to the Nuclear Power Plant construction site.\p...Hey, wait a sec. Are you {PLAYER}?\pI got orders to take ya to the Power Plant.\pBut yer just a kid. What's Chief Kellyn thinkin'?")
        # UNHANDLED: move route — see unhandled[]
        msgbox("???: Hey, wait a sec!!")
        # UNHANDLED: move route — see unhandled[]
        # UNHANDLED: move route — see unhandled[]
        # UNHANDLED: command 207 show animation — see unhandled[]
        msgbox("{PLAYER}, are you going to the Power Plant?")
        msgbox("I wanna come too!")
        # UNHANDLED: move route — see unhandled[]
        msgbox("Aw, geez, now there's TWO kids?\pI gotta radio the boss about this...")
        msgbox("Hello? I got a situation out here on Route 7. These two kids're askin' to go to the power plant. One of 'em looks like the kid that the Rangers told us about. The other one's got crazy red hair. Kinda looks like Boss's hair, actually...")
        msgbox("...")
        msgbox("Huh? You serious? All right...")
        msgbox("...... ......")
        msgbox("The boss says I should bring you both over.\pDunno what he's thinkin', but I got orders, so hop on, both of ya.")
        msgbox("Wahoo!\nI'm gonna see my dad!")
        fadescreen(FADE_TO_BLACK)
        warp(MAP_URANIUM_122, 17, 35)
        fadescreen(FADE_FROM_BLACK)
    }
    release
    end
}

