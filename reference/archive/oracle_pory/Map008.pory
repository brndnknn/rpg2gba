script Map008_EV045_Trainer2_Page1 {
    lock
    msgbox("Argh! What's wrong with this Pokémon?\nMy Capture Styler doesn't work on it!")
    msgbox("Grrrrrr!")
    msgbox("Heeeeelp!")
    # UNHANDLED: move route — see unhandled[]
    clearflag(FLAG_RESCUED_RANGER_NUCLEAR_TANCOON)
    # UNHANDLED: command 111 pbWildBattle scripted wild encounter (TANCOON Lv25) — see unhandled[]
    setvar(VAR_RANGER_NUCLEAR_EVENT_STAGE, 2)
    # UNHANDLED: move route — see unhandled[]
    msgbox("*pant* *pant*\nThank you... I don't know what was wrong with that thing. It was a weird color...\pI thought it was maybe a Shiny Pokémon, but it didn't act normal either.")
    msgbox("And my Styler couldn't calm it down at all.\pIt was really trying to attack me. I've never seen a Pokémon do that...\pI owe you one, kid. But you should be careful.")
    msgbox("I think there might be more of these things out there...")
    setflag(FLAG_RESCUED_RANGER_NUCLEAR_TANCOON)
    release
    end
}

