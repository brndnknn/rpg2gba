script Map008_EV050_Page1 {
    lockall
    # UNHANDLED: move route — see unhandled[] (Ranger NPC repositions to the player and turns to face them)
    msgbox("???")
    # UNHANDLED: move route — see unhandled[] (player and Ranger step into position)
    msgbox("RRRRROOOOAAARRRR!!!!!!")
    msgbox("W-what was that...?!")
    setvar(VAR_RANGER_NUCLEAR_EVENT_STAGE, 5)
    msgbox("HOLY SHINX!\nI'm outta here!")
    # UNHANDLED: move route — see unhandled[] (Ranger flees off-screen)
    setflag(FLAG_RESCUED_RANGER_NUCLEAR_TANCOON)
    # UNHANDLED: command 111 scripted wild battle pbWildBattle(GYARADOS, Lv28) — see unhandled[]; the block below is the victory branch, emitted unconditionally
    setvar(VAR_RANGER_NUCLEAR_EVENT_STAGE, 6)
    # UNHANDLED: move route — see unhandled[] (Ranger walks back to the player)
    msgbox("Phew...\nSorry I ran away. I've never been so scared!\pI mean, did you see the size of that thing? Those blank, soulless eyes?\pSheesh, just thinking about it now makes me shiver!")
    msgbox("Besides, I saw how you handled those other Pokémon back on the bridge. You're clearly a very capable trainer.")
    msgbox("Call it a hunch, but I bet that the radiation from the power plant is what caused those Pokémon to go crazy and attack.\pAnyway, it looks like this area is secure for now.\pThe boat that Kellyn said you should take is just over there.")
    msgbox("Take care, {PLAYER}! Be safe!")
    # UNHANDLED: move route — see unhandled[] (Ranger walks away and exits)
    setvar(VAR_RANGER_NUCLEAR_EVENT_STAGE, 7)
    setflag(FLAG_RANGER_NUCLEAR_TANCOON_DEPARTED)
    clearflag(FLAG_RESCUED_RANGER_NUCLEAR_TANCOON)
    releaseall
    end
}

