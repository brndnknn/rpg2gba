script Map008_EV015_Page1 {
    lock
    clearflag(FLAG_THEO_RIVAL_CUTSCENE_PRIMED)
    setflag(FLAG_THEO_RIVAL_BATTLE_IN_PROGRESS)
    # UNHANDLED: move route — Theo (event 14) walks down toward the player — see unhandled[]
    msgbox("Theo: Hey! Issat who I think it is? Yeah! It's {PLAYER}! So... so you survived the trip here, huh?")
    # UNHANDLED: command 111 — item-quantity script condition ($PokemonBag.pbQuantity(PBItems::PST)>0) — see unhandled[]
    msgbox("A-anyway, I blazed straight through Rochfale. What a boring town! An' I've been training ever since. I'm gonna beat that Gym Leader before you do, {PLAYER}! But first, I'll beat you!")
    msgbox("Don't think I'll go easy just 'cause of Comet Cave!")
    if (flag(FLAG_PLAYER_STARTER_CHOICE_A)) {
        trainerbattle_single(TRAINER_RIVAL_THEO_7, "", "Gyaaah! I picked the wrong starter!")
        msgbox("*sniffle* U-ugh... I-- I-- I don't care what happens! My Pokémon are the strongest, they were just weak from all the battling that we'd done before we fought!")
        msgbox("A-anyway, they d-did get some experience from this battle...")
        msgbox("I know! I'm-a challenge the Gym right now! An' I'll get ahead of you, {PLAYER}! You just see!")
        # UNHANDLED: move route — player turns to face Theo — see unhandled[]
        # UNHANDLED: move route — Theo (event 14) walks off down the path — see unhandled[]
        setflag(FLAG_DEFEATED_RIVAL_THEO_BEACH)
        clearflag(FLAG_THEO_RIVAL_BATTLE_IN_PROGRESS)
    } elif (flag(FLAG_PLAYER_STARTER_CHOICE_C)) {
        trainerbattle_single(TRAINER_RIVAL_THEO_9, "", "Gyaaah! I picked the wrong starter!")
        msgbox("*sniffle* U-ugh... I-- I-- I don't care what happens! My Pokémon are the strongest, they were just weak from all the battling that we'd done before we fought!")
        msgbox("A-anyway, they d-did get some experience from this battle...")
        msgbox("I know! I'm-a challenge the Gym right now! An' I'll get ahead of you, {PLAYER}! You just see!")
        # UNHANDLED: move route — player turns to face Theo — see unhandled[]
        # UNHANDLED: move route — Theo (event 14) walks off down the path — see unhandled[]
        setflag(FLAG_DEFEATED_RIVAL_THEO_BEACH)
        clearflag(FLAG_THEO_RIVAL_BATTLE_IN_PROGRESS)
    } else {
        trainerbattle_single(TRAINER_RIVAL_THEO_8, "", "Gyaaah! I picked the wrong starter!")
        msgbox("*sniffle* U-ugh... I-- I-- I don't care what happens! My Pokémon are the strongest, they were just weak from all the battling that we'd done before we fought!")
        msgbox("A-anyway, they d-did get some experience from this battle...")
        msgbox("I know! I'm-a challenge the Gym right now! An' I'll get ahead of you, {PLAYER}! You just see!")
        # UNHANDLED: move route — player turns to face Theo — see unhandled[]
        # UNHANDLED: move route — Theo (event 14) walks off down the path — see unhandled[]
        setflag(FLAG_DEFEATED_RIVAL_THEO_BEACH)
