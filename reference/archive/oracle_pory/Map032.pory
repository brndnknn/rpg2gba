script Map032_EV015_Rock_Page1 {
    lock
    # UNHANDLED: command 111 Kernel.pbRockSmash — Rock Smash field-move check, no flag/var equivalent; see unhandled[]
    # This event is an Essentials Rock Smash rock: smash → shake animation → erase + roll a wild encounter,
    # with a softlock-recovery fallback. In pokeemerald this is engine-driven (metatile behavior +
    # EventScript_RockSmash), not a per-event script. Mappable inner pieces (pbEraseThisEvent →
    # removeobject + setflag(FLAG_MAP032_EVENT015_SSA); self-switch A → same flag) live inside
    # untranslatable script-condition branches, so the whole page is deferred. See unhandled[].
    release
    end
}

script Map032_EV015_Rock_Page2 {
    # Post-smash invisible state (event erased after self-switch A); no actions.
    end
}


