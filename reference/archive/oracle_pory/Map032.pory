script Map032_EV012_Page1 {
    lock
    faceplayer
    random(3)
    copyvar(VAR_THEO_FOLLOW_CHATTER, VAR_RESULT)
    if (var(VAR_THEO_FOLLOW_CHATTER) == 0) {
        msgbox("Moki Town is so nice and peaceful, and everyone knows one another. I'd much rather live here than in a big city.")
    }
    if (var(VAR_THEO_FOLLOW_CHATTER) == 1) {
        msgbox("My daughter is now a Trainer, did you know? She is training her Chyinmunk in Route 01. Say hi to her if you see her.")
    }
    if (var(VAR_THEO_FOLLOW_CHATTER) == 2) {
        msgbox("Today is a nice day, isn't it? Seems like it always is around here.")
    }
    release
    end
}

script Map032_EV012_Page2 {
    lock
