script Map032_EV080_Page1 {
    lockall
    msgbox("Hey, wait up!!!")
    # UNHANDLED: command 241 Play BGM (PU-Rival Theme) — see unhandled[]
    # UNHANDLED: move route — player walked into the scene (loop positions player at y==34) — see unhandled[]
    # UNHANDLED: move route — player faces down — see unhandled[]
    # UNHANDLED: move route — rival (event 81) approaches the player — see unhandled[]
    msgbox("Um... hi.\nIt's good to see you, {PLAYER}.\pGuess we came full circle, huh\nWe're back in Moki Town,\nwhere it all started...")
    msgbox("...")
    msgbox("Hey, I wanted to say congrats\nagain on becoming Champion.\pHahaha, you must be sick of hearing that by now.")
    msgbox("Well, you deserve it!\nWhat you did up on that stage...\pfacing off versus Gamma Urayne...\pThere's nobody in the region more special than you.")
    msgbox("I mean it!!")
    msgbox("...Oh yeah, dad wanted me to tell you to come to our house when you've got a minute.")
    msgbox("I think he has something to give you.\pSee ya there!")
    # UNHANDLED: move route — rival (event 81) walks away — see unhandled[]
    # UNHANDLED: command 241 Play BGM (PU-Moki Town) — see unhandled[]
    setflag(FLAG_MAP032_EVENT081_SSA)
    setflag(FLAG_MAP032_EVENT080_SSA)
    releaseall
    end
}

