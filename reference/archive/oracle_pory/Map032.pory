script Map032_EV009_Trainer6_Page3 {
    lock
    msgbox("<--Road to Kevlar Town -- Moki Town-->")
    msgbox("Hey there, {PLAYER}!\nNow that you and Theo are here,\nit's time to begin your first lesson as a\nPokémon Trainer and a field research aid.")
    msgbox("Wild Pokémon, as you probably already\nknow, inhabit tall grass.")
    msgbox("But that's not the only place - you can\nalso find them in caves, in water, and even in cities if you know where to look.")
    msgbox("Still, tall grass is going to be your\nbest bet for finding new Pokémon.")
    msgbox("Now, I'll leave the rest to you both!\nHere, take these.")
    setflag(FLAG_SYS_POKEDEX_GET)
    msgbox("[{PLAYER} and Theo received a Pokédex!]")
    msgbox("That PokéDex is an encyclopedia that will automatically update itself whenever you encounter or catch a new Pokémon.")
    msgbox("It's very important for my research, so make sure to fill it out as much as possible!")
    msgbox("Also, I want you to have these.")
    giveitem(ITEM_POKE_BALL, 5)
    msgbox("Poké Balls are necessary for\ncatching Pokémon, of course.\nWhat's that thing the kids always say?\n\"Gotta Catch 'Em All!\"")
    msgbox("If you run out, you can pick up\nsome more at any Poké Mart.\nMoki Town doesn't have one of those...\nbut there's one in Kevlar Town on the other side of Route 01.\nSo, with that said...\nyour lesson is now over.")
    msgbox("Oh, but you two have PokéPods, don't you?\nHere, let me input my number.")
    msgbox("You can give me a call anytime, and I'll take a look at how your PokéDex is coming along. If you do a good job collecting many different kinds of Pokémon, I might even have special rewards for you.")
    msgbox("With that said, I'm going back to my Lab.\nBest of luck on your journeys, both of you!")
    msgbox("{PLAYER}, I don't care that you got the stronger starter. I'm still gonna be the best Trainer ever! I'll catch tons of Pokémon and we'll win every battle!")
    msgbox("You just wait and see!!")
    setvar(VAR_AUNTIE_VISIT_STAGE, 4)
    release
    end
}

