        msgbox("I wonder what kind of Pokémon lives in this pond? Probably just Magikarp...")
    }
    if (var(VAR_THEO_FOLLOW_CHATTER) == 1) {
        msgbox("Professor Bamb'o has a lab in that house on the cliff. I wonder why he lives in Moki Town, of all places?")
    }
    release
    end
}

