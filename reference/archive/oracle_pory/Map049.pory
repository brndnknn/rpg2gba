script Map049_EV001_Auntie_Page4 {
    lock
    faceplayer
    setflag(FLAG_BLACKBELT_POP_DEFEATED)
    msgbox("Hello, honey! Take a break from all that tiring adventuring?")
    healparty
    msgbox("Your Pokémon were healed...")
    msgbox("It's quiet without you around, you know...")
    random(13)
    copyvar(VAR_THEO_FOLLOW_CHATTER, VAR_RESULT)
    if (var(VAR_THEO_FOLLOW_CHATTER) == 0) {
        msgbox("I've been playing your Wii tennis. It feels good to get moving.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 1) {
        msgbox("I joined a swim aerobics class. It meets every Tuesday.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 2) {
        msgbox("I asked our neighbors to help set up the internet.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 3) {
        msgbox("Those kids next door seem very interested in your Wii. I let them play it.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 4) {
        msgbox("I've been getting into indie game development. My latest project is called \"Pokémon Agate.\"")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 5) {
        msgbox("I haven't seen that nice boy Theo around lately. I wonder where he went?")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 6) {
        msgbox("Don't you know, I tried to talk to Cam lately, and he just gave me the cold shoulder! How rude!")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 7) {
        msgbox("Have you heard from my nephew-- your father-- lately? Must be tough, being a ranger.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 8) {
        msgbox("I was thinking of getting a pet Pokémon to keep me company.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 9) {
        msgbox("Did you ever talk to your neighbor Cam? He's an electrician, you know. Seems to be moving up in the world.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 10) {
        msgbox("You know, back when I was a little girl, I was quite a looker. *sigh*")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 11) {
        msgbox("I was watching the television, and they said your mother's name! Something about a new plant, I forget.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 12) {
        msgbox("Beaten any of those gym leaders yet?")
    }
    clearflag(FLAG_BLACKBELT_POP_DEFEATED)
    release
    end
}

script Map049_EV001_Auntie_Page5 {
    lock
    faceplayer
    msgbox("Running off on another adventure, eh, {PLAYER}? Why don't you stay and rest up a while?")
    healparty
    msgbox("Your Pokémon were healed...")
    msgbox("It's so nice to have company in the house again. Tonight, I'm making a big dinner for everyone!")
    release
    end
}


