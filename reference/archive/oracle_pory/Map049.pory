script Map049_EV018_Page1 {
    lockall
    # UNHANDLED: move route — see unhandled[]
    # UNHANDLED: animation (command 207) — see unhandled[]
    # UNHANDLED: move route — see unhandled[]
    msgbox("Good morning {PLAYER}!")
    msgbox("Your parents are in the other room.\nCome, let us see them.")
    # UNHANDLED: move route — see unhandled[]
    msgbox("Lucille...\nPoor dear...\pYour father brought her home not too long ago.\pShe hasn't woken up yet.\nIt may be some time before she recovers.\pStill... After 10 long years...\nIt's good to have the entire family together under one roof.")
    msgbox("It's thanks to you, {PLAYER}.\nYou made our family whole again.\pI feel as though a huge weight has been lifted from my shoulders.")
    msgbox("I'm just happy we're all together again.")
    msgbox("...Oh! That's the oven timer!\nI baked us all some cookies.\nLet me go and get them.")
    # UNHANDLED: move route — see unhandled[]
    msgbox("Lucille...\pThere's no way to know how much damage the CURIE Interface did to her mind, or how long it will take to undo it.\pBut I'm willing to do whatever it takes.\nI've stepped down as Chief of the Tandor Rangers.\pLooking after her is my number one priority now.\pEventually...\nI'll see your eyes open again, Lucille.")
    # UNHANDLED: move route — see unhandled[]
    msgbox("I made everyone cookies!")
    # UNHANDLED: move route — see unhandled[]
    msgbox("Here you are!")
    giveitem(ITEM_LAVA_COOKIE, 1)
    msgbox("Don't eat it too quickly, now.\nIt's still fresh out of the oven.")
    msgbox("Oh, {PLAYER}...\nA letter arrived in the mail for you.\pIt seems that since you became Champion of Tandor, you've been receiving a lot of fan mail.\pIt's on the table in the other room.\nWhy don't you open it?")
    fadescreen(FADE_TO_BLACK)
    setflag(FLAG_MAP049_EVENT018_SSA)
    setflag(FLAG_MAP049_EVENT019_SSA)
    fadescreen(FADE_FROM_BLACK)
    releaseall
    end
}

script Map049_EV018_Page2 {
    end
}


script Map049_EV020_Page1 {
    lock
    faceplayer
    if (var(VAR_TEMP_POKEMON_CHOICE) == 0) {
        msgbox("I won't rest until a cure is found for Lucille's condition.\pBut, just standing by her side,\nable to hold her in my arms...\nThat is enough, for now.")
        addvar(VAR_TEMP_POKEMON_CHOICE, 1)
    } elif (var(VAR_TEMP_POKEMON_CHOICE) == 1) {
        msgbox("Of course I'm incredibly proud of you\nfor becoming Champion of Tandor.\pYou've achieved as much as I did in my heyday as a Pokémon Ranger Cadet and then as a fully-fledged Ranger.\pHeroism runs in the family, I suppose.")
        addvar(VAR_TEMP_POKEMON_CHOICE, 1)
    } elif (var(VAR_TEMP_POKEMON_CHOICE) == 2) {
        msgbox("This kind of life...\nI'd forgotten what it was like.\nI spent so many years in a hurry,\nrushing from crisis to crisis.\pAnd... if I'm being honest...\nmy age has been catching up with me.\nI'm 45 years old.\nI'm not as spry as when I was younger.\pA break from the action like this is... nice.")
        addvar(VAR_TEMP_POKEMON_CHOICE, 1)
    } elif (var(VAR_TEMP_POKEMON_CHOICE) >= 3) {
        msgbox("Empirilla's not with me any more.\nIt returned to the Baykal Forest, its home.\pYou know, despite our partnership it was never truly my Pokémon. It stood by my side because of its choice. And it left because of its own choice, too.\pBut I know we'll meet again.")
        setvar(VAR_TEMP_POKEMON_CHOICE, 0)
    }
    release
    end
}


script Map049_EV021_Page1 {
    lock
    # UNHANDLED: command 355 displayNinjaLetter — see unhandled[]
    # UNHANDLED: move route — see unhandled[]
    msgbox("What did the letter say?\nIt looked so formal I didn't want to touch it.")
    msgbox("...")
    msgbox("Well... that's certainly vague.\nThey wouldn't call for aid unless it was something serious, though.")
    msgbox("I wonder could it have to do with pirates?")
    msgbox("There's a piracy problem in East Tandor.\nI know that the Rangers over there are\nhaving a hard time keeping them under control.\nMaybe they could use some help too.")
    msgbox("The East Tandor Ranger HQ is located in Angelure Town.")
    msgbox("It's a scenic resort area, but it's also\nknown as a haven for pirates and other riffraff.\nThe further West you sail in the Tandor Sea, the more treacherous and lawless it becomes...")
    msgbox("But, if there's anybody that can deal with those kinds of conditions, it's you, {PLAYER}.")
    msgbox("...Now. If you'll excuse me,\nhave to tend to Lucille.")
    msgbox("But if you ever need to find me...\nYou'll know where I am.")
    fadescreen(FADE_TO_BLACK)
    setflag(FLAG_MAP049_EVENT002_SSA)
    setflag(FLAG_MAP049_EVENT021_SSA)
    warp(MAP_URANIUM_48, 4, 6)
    warp(MAP_URANIUM_49, 6, 8)
    fadescreen(FADE_FROM_BLACK)
    msgbox("You've reached the end of this portion of the URANIUM post-game. More to come!")
    msgbox("In the meantime, there's someone in Venesi Town who desperately needs your help...")
    release
    end
}

