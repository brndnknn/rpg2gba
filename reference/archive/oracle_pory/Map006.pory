script Map006_EV002_Nowhere {
    msgbox("Ok!")
    release
    end
}


script Map006_EV010_Page1 {
    # UNHANDLED: move route — see unhandled[]
    warp(MAP_URANIUM_5, 13, 4)
    end
}

