script CommonEvent_077 {
    random(4)
    copyvar(VAR_THEO_FOLLOW_CHATTER, VAR_RESULT)
    if (var(VAR_THEO_FOLLOW_CHATTER) == 0) {
        msgbox("...Did you hear that?\nNo, it must've just been my imagination...")
    }
    if (var(VAR_THEO_FOLLOW_CHATTER) == 1) {
        msgbox("Scared, {PLAYER}?\n...Me neither!")
    }
    if (var(VAR_THEO_FOLLOW_CHATTER) == 2) {
        msgbox("Davern was really hard to beat! But my Pokémon\ngave it their all.")
    }
    if (var(VAR_THEO_FOLLOW_CHATTER) == 3) {
        msgbox("Your Pokémon are pretty cool... but not as cool as\nmine!")
    }
    release
    end
}


