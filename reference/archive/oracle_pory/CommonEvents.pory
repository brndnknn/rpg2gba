script CommonEvent_012 {
    lockall
    fadescreen(FADE_TO_BLACK)
    delay(8)
    # UNHANDLED: conditional branch on $game_map.map_id == 71 — no Poryscript
    #   equivalent for a current-map check; the reset warp it gates is untranslatable here — see unhandled[]
    # Abyssal Venesi (map 71) reset path: warp(MAP_URANIUM_71, 18, 73), then a move route
    # UNHANDLED: move route — player walks up one tile after the warp — see unhandled[]
    # UNHANDLED: conditional branch on $game_map.map_id == 213 — see unhandled[]
    # Nestlands (map 213) reset path: warp(MAP_URANIUM_208, 9, 10)
    releaseall
    end
}


script CommonEvent_035 {
    msgbox("......\p......")
    msgbox("Ah, hello {PLAYER}.\nAre you calling to evaluate your PokéDex?")
    msgbox("I'll reward you for reaching certain milestones in your collection.", MSGBOX_YESNO)
    if (var(VAR_RESULT) == 1) {
        # UNHANDLED: commands 355/655 — PokéDex reward-tier evaluation (PROFREWARDS table, $Trainer.pokedexSeen/Owned, jvNextRewardPhone) drives every milestone hint and reward; unbuilt feature — see unhandled[]
    } else {
        msgbox("No? Ah well, then...\nUntil next time!")
    }
    msgbox("Click!\n......\p......")
    return
}


script CommonEvent_037 {
    if (var(VAR_GYM8_PROGRESS) == 0) {
        setvar(VAR_GYM8_WHITE_TILES, 44)
        setvar(VAR_GYM8_DARK_TILES, 16)
        setvar(VAR_GYM8_PROGRESS, 1)
        return
    }
    if (var(VAR_GYM8_PROGRESS) == 1) {
        setvar(VAR_GYM8_WHITE_TILES, 57)
        setvar(VAR_GYM8_DARK_TILES, 87)
        setvar(VAR_GYM8_PROGRESS, 2)
        return
    }
    if (var(VAR_GYM8_PROGRESS) == 2) {
        setvar(VAR_GYM8_WHITE_TILES, 0)
        setvar(VAR_GYM8_DARK_TILES, 0)
        setvar(VAR_GYM8_PROGRESS, 3)
        return
    }
    end
}


