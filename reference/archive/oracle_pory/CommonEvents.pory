script CommonEvent_081 {
    random(5)
    copyvar(VAR_THEO_FOLLOW_CHATTER, VAR_RESULT)
    if (var(VAR_THEO_FOLLOW_CHATTER) == 0) {
        msgbox("{PLAYER}, we should go upstairs to check on your father, Kellyn.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 1) {
        msgbox("I wonder if Theo is here already?")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 2) {
        msgbox("We've made a lot of progress on finding a cure for Nuclear-infected Pokémon.")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 3) {
        msgbox("Cameron is still alive... it's a miracle!")
    } elif (var(VAR_THEO_FOLLOW_CHATTER) == 4) {
        msgbox("Now that CURIE has shown themselves, it raises even more questions.")
    }
    return
}


script CommonEvent_082 {
