script CommonEvent_086 {
    msgbox("Do you want me to use the Dream Visualizer?")
    # CHECK: 3-way choice - multichoice list MULTI_DREAM_VISUALIZER must be defined in Phase 5; see unhandled[]
    multichoice(0, 0, MULTI_DREAM_VISUALIZER, TRUE)
    switch (var(VAR_RESULT)) {
        case 0:
            return
        case 1:
            # UNHANDLED: capture player map id/x/y into vars (RPG Maker Control Variables, player position) - see unhandled[]
            warp(MAP_URANIUM_70, 9, 8)
            # UNHANDLED: warp back to captured position via variables (dynamic map id) - see unhandled[]
            return
        case 2:
            # UNHANDLED: command 355 $Trainer.bagdisabled=false - re-enable the bag, no field equivalent - see unhandled[]
            # UNHANDLED: command 355 $Trainer.party=pbGet(28), gated on flag(FLAG_DREAM_STORY_PARTY_SWAPPED) - restore stored party, no field equivalent - see unhandled[]
            fadescreen(FADE_FROM_BLACK)
            clearflag(FLAG_DREAM_VISUALIZER_CONTROLS)
            if (flag(FLAG_DREAM_STORY_PARTY_SWAPPED)) {
                warp(MAP_URANIUM_97, 28, 59)
            } else {
                warp(MAP_URANIUM_204, 80, 4)
            }
            clearflag(FLAG_DREAM_VISUALIZER_HUD)
            clearflag(FLAG_DREAM_VISION_STAGE_1)
            clearflag(FLAG_DREAM_VISION_STAGE_2)
            clearflag(FLAG_DREAM_VISION_STAGE_3)
            clearflag(FLAG_DREAM_ACTIVE)
            return
    }
    return
}


script CommonEvent_087 {
    msgbox("Do you want me to use the Dream Visualizer?")
    # UNHANDLED: command 102 — 3-option Show Choices, needs a multichoice list to set VAR_RESULT; see unhandled[]
    switch (var(VAR_RESULT)) {
        case 0:
            return
        case 1:
            # UNHANDLED: command 122 — saves player map x/y/id to vars; see unhandled[]
            warp(MAP_URANIUM_70, 9, 7)
            # UNHANDLED: command 201 — warp to saved variable coordinates; see unhandled[]
            return
        case 2:
            msgbox("Hold still.")
            # UNHANDLED: move route — Fennel NPC animation; see unhandled[]
            # UNHANDLED: command 207 — show animation 231; see unhandled[]
            # UNHANDLED: move route — player animation; see unhandled[]
            # UNHANDLED: command 355 $Trainer.bagdisabled=false — re-enable bag, no equivalent; see unhandled[]
            clearflag(FLAG_DREAM_VISUALIZER_HUD)
            warp(MAP_URANIUM_204, 80, 4)
            clearflag(FLAG_DREAM_ACTIVE)
            return
    }
    return
}


