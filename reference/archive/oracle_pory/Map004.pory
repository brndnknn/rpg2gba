script Map004_EV004_Page1 {
    lock
    faceplayer
    msgbox("It's rather sad... there's so much stuff here, yet I can only buy eight or so different items at the register. Where's the fun in that?")
    release
    end
}

script Map004_EV005_Page1 {
    lock
    faceplayer
    msgbox("I wrote a song about Great Balls and how excellent they are. Wanna hear it? ...No?")
    release
    end
}
