# Copy to .env and fill in paths for your machine. .env is gitignored.
# These are read by rpg2gba.pipeline at startup (shell env wins over .env).

# Unpacked Uranium source tree (the dir containing Data/*.dat).
RPG2GBA_URANIUM_SRC=/path/to/Pokemon_Uranium/_unpacked

# Clone of rh-hideout/pokeemerald-expansion (the build target / fork).
RPG2GBA_POKEEMERALD=/path/to/pokeemerald-expansion

# Optional: override output dir (defaults to ./output).
# RPG2GBA_OUTPUT=output

# Optional: Ollama server (Phase 4).
# OLLAMA_HOST=http://localhost:11434
