# hand conversion (2026-07-05): the Pokédex-ceremony cutscene — the slice's one branch-heavy story event (reference/slice1_queue_readthrough.md §Hand). Hand-authored deltas over the transpiler's own output (everything else copied verbatim): (1) the pages' RMXP "$game_player.x==17 -> road-sign text + Exit Event Processing" fork becomes getplayerxy + early exit; (2) page-3's "$game_player.y<=43" player reposition becomes a walk_down/face_left route; (3) the var-151 starter readback (x=pbGet(151); x=0 if x==3; var1=x; var3=list[x]; "Go! \v[3]!") becomes copyvar(VAR_TEMP_POKEMON_CHOICE, VAR_POKEMONTEST) + clamp + per-branch literal "Go! <starter>!" msgboxes; (4) $Trainer.pokedex=true becomes the canonical setflag(FLAG_SYS_POKEDEX_GET) + special(SetUnlockedPokedexFlags) pair (Birch/Oak-lab pattern, engine data/maps/LittlerootTown_ProfessorBirchsLab/scripts.inc); (5) RMXP change-graphic move routes (PU-Orchynx/Raptorch/Eletux on event 77, PU-POKEBALL on event 76) have no script-callable live-swap in the fork (verified: no such macro in asm/macros/event.inc; VAR_OBJ_GFX resolves at spawn only, src/event_object_movement.c:3236) — v1 keeps the visibility/pose choreography on the events' static sprites and defers per-scene graphics to task-4 NPC gfx; (6) anim 104 "Rustle" -> exclamation emote, anim 18 "Scratch hit" -> dropped (hit conveyed by the freeze pose); (7) RMXP step-forward/step-backward gestures -> walk_in_place_right (fork has no relative-to-facing step tokens).

# Trainer_6
script Map032_EV009_Page1 {
    lock
    # RMXP: if $game_player.x==17 -> road-sign text + Exit Event Processing (code 115)
    getplayerxy(VAR_TEMP_0, VAR_TEMP_1)
    if (var(VAR_TEMP_0) == 17) {
        msgbox(format("<--Road to Kevlar Town -- Moki Town-->"))
        release
        end
    }
    msgbox(format("It's dangerous to go out without a Pokémon."))
    delay(10)
    applymovement(OBJ_EVENT_ID_PLAYER, Map032_EV009_Page1_Move1)
    waitmovement(0)
    release
    end
}

movement Map032_EV009_Page1_Move1 {
    walk_right
}

# Trainer_6
script Map032_EV009_Page2 {
    lock
    # RMXP: if $game_player.x==17 -> road-sign text + Exit Event Processing (code 115)
    getplayerxy(VAR_TEMP_0, VAR_TEMP_1)
    if (var(VAR_TEMP_0) == 17) {
        msgbox(format("<--Road to Kevlar Town -- Moki Town-->"))
        release
        end
    }
    msgbox(format("Hey there, {PLAYER}! I want to show you and Theo how to catch a Pokémon. Can you go get him? He should be in his house."))
    applymovement(OBJ_EVENT_ID_PLAYER, Map032_EV009_Page2_Move1)
    waitmovement(0)
    release
    end
}

movement Map032_EV009_Page2_Move1 {
    walk_right
}

# Trainer_6
script Map032_EV009_Page3 {
    lock
    # RMXP: if $game_player.x==17 -> road-sign text + Exit Event Processing (code 115)
    getplayerxy(VAR_TEMP_0, VAR_TEMP_1)
    if (var(VAR_TEMP_0) == 17) {
        msgbox(format("<--Road to Kevlar Town -- Moki Town-->"))
        release
        end
    }
    # RMXP: if $game_player.y<=43 -> walk the player down into the scene and
    # face the professor (route [move_down, turn_left] on the player)
    if (var(VAR_TEMP_1) <= 43) {
        applymovement(OBJ_EVENT_ID_PLAYER, Map032_EV009_Page3_MoveIntoPlace)
        waitmovement(0)
    }
    # audio (code 241): PU-Radio_ Oak
    msgbox(format("Hey there, {PLAYER}! Now that you and Theo are here, it's time to begin your first lesson as a Pokémon Trainer and a field research aid."))
    delay(10)
    msgbox(format("Now, watch closely."))
    applymovement(16, Map032_EV009_Page3_Move1)
    waitmovement(0)
    delay(20)
    msgbox(format("Wild Pokémon, as you probably already know, inhabit tall grass."))
    msgbox(format("But that's not the only place - you can also find them in caves, in water, and even in cities if you know where to look."))
    msgbox(format("Still, tall grass is going to be your best bet for finding new Pokémon."))
    delay(10)
    msgbox(format("Simply take a few steps in and..."))
    applymovement(16, Map032_EV009_Page3_Move2)
    waitmovement(0)
    delay(8)
    # anim 104 "Rustle" over the hidden Chyinmunk -> exclamation emote (hand, v1)
    applymovement(76, Common_Movement_ExclamationMark)
    waitmovement(0)
    delay(5)
    applymovement(76, Map032_EV009_Page3_Move3)
    waitmovement(0)
    delay(5)
    # audio (code 250): 007Cry
    delay(10)
    msgbox(format("Look! It's a wild Chyinmunk! They're very common around here. It hasn't noticed me yet, so now's my chance..."))
    # RMXP: x=pbGet(151); x=0 if x==3; $game_variables[1]=x; $game_variables[3]=list[x]
    # (var 151 = Map050 starter-pick index; clamp guards Map050's other 1-based reuse)
    copyvar(VAR_TEMP_POKEMON_CHOICE, VAR_POKEMONTEST)
    if (var(VAR_TEMP_POKEMON_CHOICE) == 3) {
        setvar(VAR_TEMP_POKEMON_CHOICE, 0)
    }
    # "Go! \v[3]!" + the event-77 reveal route folded into one branch per starter;
    # graphic swap to PU-Orchynx/PU-Raptorch/PU-Eletux (route code 41) deferred to
    # task-4 NPC gfx (no script-callable live swap in the fork); SE "recall" dropped
    if (var(VAR_TEMP_POKEMON_CHOICE) == 0) {
        msgbox(format("Go! Orchynx!"))
        applymovement(77, Map032_EV009_Page3_MoveShowStarter)
        waitmovement(0)
    }
    if (var(VAR_TEMP_POKEMON_CHOICE) == 1) {
        msgbox(format("Go! Raptorch!"))
        applymovement(77, Map032_EV009_Page3_MoveShowStarter)
        waitmovement(0)
    }
    if (var(VAR_TEMP_POKEMON_CHOICE) == 2) {
        msgbox(format("Go! Eletux!"))
        applymovement(77, Map032_EV009_Page3_MoveShowStarter)
        waitmovement(0)
    }
    delay(10)
    msgbox(format("This little guy was the other starter Pokémon you could have received."))
    msgbox(format("I think he's taken a shine to me, and I rather like him too... so I'm gonna keep him."))
    msgbox(format("Now! The next step is to weaken the enemy Pokémon to make it easier to catch."))
    delay(10)
    if (var(VAR_TEMP_POKEMON_CHOICE) == 0) {
        msgbox(format("Orchynx! Use Scratch!"))
    }
    if (var(VAR_TEMP_POKEMON_CHOICE) == 1) {
        msgbox(format("Raptorch! Use Scratch!"))
    }
    if (var(VAR_TEMP_POKEMON_CHOICE) == 2) {
        msgbox(format("Eletux! Use Tackle!"))
    }
    delay(8)
    # anim 18 "Scratch hit" on the Chyinmunk — no OW attack animation in the fork;
    # the hit is conveyed by the freeze pose below (hand, v1)
    delay(15)
    # route [turn_right, stepping-anime-off]: the flinch/weakened hit pose
    applymovement(76, Map032_EV009_Page3_MoveHitPose)
    waitmovement(0)
    # audio (code 250): 007Cry
    msgbox(format("Chiiiin!"), MSGBOX_AUTOCLOSE)
    delay(15)
    msgbox(format("Now that it's weakened, now's my chance to catch it. Poké Ball, go!"))
    # audio (code 250): throw
    # route [graphic->PU-POKEBALL, anims off, direction fix]: the thrown ball on the
    # ground — graphic swap deferred to task-4 NPC gfx; pose/lock kept (hand, v1)
    applymovement(76, Map032_EV009_Page3_MoveBallPose)
    waitmovement(0)
    delay(8)
    # audio (code 250): ballshake
    delay(12)
    # audio (code 250): ballshake
    delay(12)
    # audio (code 250): ballshake
    delay(12)
    # audio (code 250): balldrop
    delay(12)
    applymovement(77, Map032_EV009_Page3_Move4)
    waitmovement(0)
    delay(12)
    applymovement(16, Map032_EV009_Page3_Move5)
    waitmovement(0)
    delay(12)
    applymovement(76, Map032_EV009_Page3_Move6)
    waitmovement(0)
    delay(20)
    applymovement(16, Map032_EV009_Page3_Move7)
    waitmovement(0)
    delay(12)
    msgbox(format("...And that's how it's done. Now, Chyinmunk are fairly easy... but you're sure to encounter Pokémon that are a lot harder to capture. For those, you might need to inflict them with status effects, or use a special Poké Ball. Ah, but I'm sure you'll get the hang of it before too long."))
    delay(12)
    msgbox(format("{PLAYER}, Theo, these are for you."))
    # RMXP step-forward/step-backward hand-over gesture (route [12,13]) — no
    # relative-to-facing step tokens in the fork; walk_in_place_right instead
    applymovement(16, Map032_EV009_Page3_MoveGesture)
    waitmovement(0)
    # $Trainer.pokedex=true -> canonical Pokédex grant (Birch/Oak-lab pattern)
    setflag(FLAG_SYS_POKEDEX_GET)
    special(SetUnlockedPokedexFlags)
    # audio (code 249): Jinlge - KeyItem
    msgbox(format("[{PLAYER} and Theo received a Pokédex!]"), MSGBOX_AUTOCLOSE)
    delay(10)
    msgbox(format("That PokéDex is an encyclopedia that will automatically update itself whenever you encounter or catch a new Pokémon."))
    msgbox(format("It's very important for my research, so make sure to fill it out as much as possible!"))
    msgbox(format("Also, I want you to have these."))
    applymovement(16, Map032_EV009_Page3_MoveGesture)
    waitmovement(0)
    giveitem(ITEM_POKE_BALL, 5)
    if (var(VAR_RESULT) != 0) {
        msgbox(format("Poké Balls are necessary for catching Pokémon, of course. What's that thing the kids always say? \"Gotta Catch 'Em All!\""))
        msgbox(format("If you run out, you can pick up some more at any Poké Mart. Moki Town doesn't have one of those... but there's one in Kevlar Town on the other side of Route 01. So, with that said... your lesson is now over."))
        msgbox(format("Oh, but you two have PokéPods, don't you? Here, let me input my number."))
    }
    # audio (code 249): Jinlge - KeyItem
    # phone: pbPhoneRegisterNPC stripped (slice1)
    delay(10)
    msgbox(format("You can give me a call anytime, and I'll take a look at how your PokéDex is coming along. If you do a good job collecting many different kinds of Pokémon, I might even have special rewards for you."))
    msgbox(format("With that said, I'm going back to my Lab. Best of luck on your journeys, both of you!"))
    delay(10)
    applymovement(16, Map032_EV009_Page3_Move8)
    waitmovement(0)
    delay(10)
    applymovement(OBJ_EVENT_ID_PLAYER, Map032_EV009_Page3_Move9)
    applymovement(2, Map032_EV009_Page3_Move10)
    waitmovement(0)
    delay(10)
    msgbox(format("{PLAYER}, I don't care that you got the stronger starter. I'm still gonna be the best Trainer ever! I'll catch tons of Pokémon and we'll win every battle!"))
    msgbox(format("You just wait and see!!"))
    applymovement(OBJ_EVENT_ID_PLAYER, Map032_EV009_Page3_Move11)
    applymovement(2, Map032_EV009_Page3_Move12)
    waitmovement(0)
    # audio (code 241): PU-Moki Town
    setvar(VAR_AUNTIE_VISIT_STAGE, 4)
    release
    end
}

movement Map032_EV009_Page3_MoveIntoPlace {
    walk_down
    face_left
}

movement Map032_EV009_Page3_MoveShowStarter {
    set_visible
}

movement Map032_EV009_Page3_MoveHitPose {
    face_right
    disable_anim
}

movement Map032_EV009_Page3_MoveBallPose {
    disable_anim
    lock_facing_direction
}

movement Map032_EV009_Page3_MoveGesture {
    walk_in_place_right
    walk_in_place_right
}

movement Map032_EV009_Page3_Move1 {
    face_left
}

movement Map032_EV009_Page3_Move2 {
    delay_4
    walk_slow_left
    delay_4
}

movement Map032_EV009_Page3_Move3 {
    set_visible
}

movement Map032_EV009_Page3_Move4 {
    set_invisible
}

movement Map032_EV009_Page3_Move5 {
    walk_left
}

movement Map032_EV009_Page3_Move6 {
    set_invisible
}

movement Map032_EV009_Page3_Move7 {
    walk_right
}

movement Map032_EV009_Page3_Move8 {
    walk_up
    walk_right
    walk_right
    walk_right
    walk_right
    walk_down
    walk_down
    walk_right
    walk_right
    walk_right
    walk_right
    walk_right
    walk_right
    walk_right
    walk_right
    set_invisible
}

movement Map032_EV009_Page3_Move9 {
    face_down
}

movement Map032_EV009_Page3_Move10 {
    face_up
}

movement Map032_EV009_Page3_Move11 {
    face_left
}

movement Map032_EV009_Page3_Move12 {
    walk_left
    walk_up
    walk_left
    walk_left
    walk_left
    walk_left
    walk_left
    walk_left
    walk_left
    walk_left
    set_invisible
}

# Trainer_6
script Map032_EV009_Page4 {
    lock
    faceplayer
    lock
    msgbox(format("<--Road to Kevlar Town -- Moki Town-->"))
    release
    release
    end
}
